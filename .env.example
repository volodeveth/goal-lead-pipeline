# Database (Neon Postgres)
# Pooled connection — used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.../DB?sslmode=require"

# Direct (non-pooled) connection — required by `prisma migrate`.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.../DB?sslmode=require"

# For integration tests (separate Neon branch). Tests auto-skip when unset.
DATABASE_URL_TEST=""

# OpenRouter (DeepSeek 3.2)
OPENROUTER_API_KEY=""
OPENROUTER_HTTP_REFERER="http://localhost:3000"
OPENROUTER_X_TITLE="Ціль Lead Pipeline"
OPENROUTER_MODEL="deepseek/deepseek-v3.2-exp"

# Telegram (BotFather)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Admin Basic Auth (/admin/*)
ADMIN_USER="admin"
ADMIN_PASSWORD="please-change-me"

# Public base URL (used in Telegram admin link)
APP_BASE_URL="http://localhost:3000"

# Optional: Upstash rate limiting (soft no-op when absent)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
